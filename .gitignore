# Fichiers générés par le build
dist/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Images lourdes / générées (Open Graph + hero + projets)
# On ignore les dossiers d'images générées, mais pas les icônes/source légers.
assets/images/hero/*
assets/images/projects/*
assets/images/og/*

# Garder le placeholder projet versionné
!assets/images/projects/placeholder.svg

# Favicons générés en masse, on garde uniquement le SVG source principal
assets/icons/favicons/*
!assets/icons/favicon.svg

# Anciennes versions volumineuses / archives
Previous_Versions/*

# README téléchargés pour les projets (générés)
src/data/readmes/*

# Secrets / config locales
.env
.env.*
*.env
*.pem
*.key